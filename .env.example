# Copy to .env and fill in. NEVER commit .env.

# From @BotFather. Treat this like a root credential — it is functionally
# equivalent to control over your Docker host.
BOT_TOKEN=

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Find yours by messaging @userinfobot. The bot refuses to start if empty.
ALLOWED_USER_IDS=

# Rate limit per user (belt-and-suspenders on top of the allowlist).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# error | warn | info | debug
LOG_LEVEL=info

# Log monitors: bounds on the per-monitor check interval (seconds). The minimum
# guards the Docker socket from being polled too aggressively.
MONITOR_MIN_INTERVAL=5
MONITOR_MAX_INTERVAL=86400

# Default cooldown (seconds) between alerts for the same monitor. After an alert
# fires, further matches are counted but not sent until this elapses — prevents
# a fast-flapping log line from flooding the chat. Override per-monitor with a
# `cooldown: <n>` line when adding one.
MONITOR_DEFAULT_COOLDOWN=300

# How many recent log lines the add-time preview (dry run) scans for matches.
MONITOR_PREVIEW_TAIL=200

# Hard ceiling on the total number of monitors (each is a recurring Docker poll
# + timer, so this bounds load on the socket-proxy).
MONITOR_MAX=50

# Max characters of a single log line/block fed to a user regex. Bounds worst-
# case regex backtracking time; longer units are truncated before matching.
MONITOR_MAX_MATCH_LEN=4000

# Host path to the Docker socket the proxy mounts. Leave unset on a normal
# Linux host (defaults to /var/run/docker.sock). Override only if your daemon's
# socket lives elsewhere:
#   OrbStack (macOS): /Users/<you>/.orbstack/run/docker.sock
#   Docker Desktop:   keep the default (/var/run/docker.sock works)
#   rootless Docker:  /run/user/<uid>/docker.sock
# DOCKER_SOCK=/Users/you/.orbstack/run/docker.sock
