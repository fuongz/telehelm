# Copy to .env and fill in. NEVER commit .env.

# From @BotFather. Treat this like a root credential — it is functionally
# equivalent to control over your Docker host.
BOT_TOKEN=

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Find yours by messaging @userinfobot. The bot refuses to start if empty.
ALLOWED_USER_IDS=

# Rate limit per user (belt-and-suspenders on top of the allowlist).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# error | warn | info | debug
LOG_LEVEL=info
